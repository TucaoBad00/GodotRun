[sub_resource type="GDScript" id="GDScript_tefeu"]
resource_name = "Game"
script/source = "extends Node2D



func _ready() -> void:
	get_tree().create_timer(60.0).timeout.connect(_go_to_menu)
	CoinManager.coin_collected.connect(_on_coin_collected)


# checagem de vitória, chamada após a coleta de qualquer moeda
func _on_coin_collected(_value : int) -> void:
	if len(get_tree().get_nodes_in_group(\"coins\")) == 1:
		get_tree().change_scene_to_file(\"res://scenes/menu.tscn\")


# ida para o menu após o tempo estipulado pelo timer na função _ready
func _go_to_menu() -> void:
	get_tree().change_scene_to_file(\"res://scenes/menu.tscn\")
"

[sub_resource type="GDScript" id="GDScript_jyhfs"]
script/source = "extends ProgressBar
@export var Player : Player

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	value = Player.stamina
"

[sub_resource type="GDScript" id="GDScript_o6xl0"]
resource_name = "cronometro"
script/source = "extends Label

@onready var timerr : Timer = $Timer
# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	text = \"%.2f s\" % timerr.time_left
"

